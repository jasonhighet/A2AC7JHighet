# Copy this file to .env and fill in your values
# Do NOT commit .env to source control

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/config_service

# Test database (separate DB used by pytest — transactions are rolled back after each test)
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/config_service_test

# Uvicorn
APP_HOST=127.0.0.1
APP_PORT=8000
