# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# LangSmith Configuration (for evaluation and tracing)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=investigator-agent

# Model Configuration
MODEL_NAME=claude-sonnet-4-5
TEMPERATURE=0.0
MAX_TOKENS=4096

# Observability Configuration
TRACE_OUTPUT_DIR=traces/

# Retry Configuration
LLM_MAX_RETRY_ATTEMPTS=3
LLM_RETRY_EXPONENTIAL_JITTER=true
TOOL_MAX_RETRY_ATTEMPTS=3
TOOL_RETRY_EXPONENTIAL_JITTER=true
